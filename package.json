{
  "name": "messenger",
  "private": true,
  "scripts": {
    "dev": "npm run db:start && concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "db:start": "node scripts/db.mjs start",
    "db:stop": "node scripts/db.mjs stop",
    "db:migrate": "npm run prisma:migrate --prefix server",
    "db:seed": "npm run prisma:seed --prefix server",
    "setup": "node scripts/setup.mjs",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
